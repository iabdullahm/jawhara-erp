// JawharaERP — Prisma Schema
// Phase 1: Inventory Module
// Note: All weights use Decimal(12, 4) for gram precision.
// All prices use Decimal(14, 4) to support varying currency precision.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum MetalType {
  GOLD
  SILVER
  PLATINUM
  PALLADIUM
  OTHER
}

enum Karat {
  K24
  K22
  K21
  K18
  K14
  K10
  K925 // Sterling silver
  K950 // Platinum
  OTHER
}

enum WeightUnit {
  GRAM
  CARAT
  PIECE
  OUNCE
}

enum ProductStatus {
  IN_STOCK         // متوفر في المخزون
  SOLD             // مُباع
  RESERVED         // محجوز لعميل (Layaway)
  IN_REPAIR        // في الصيانة
  IN_MANUFACTURING // في التصنيع
  CONSIGNMENT_OUT  // بالأمانة عند طرف آخر
  LOST             // مفقود
  WRITTEN_OFF      // مشطوب
}

enum OwnershipType {
  OWNED        // مخزون مملوك
  CONSIGNMENT  // مخزون بالأمانة (من مورد)
  OLD_GOLD     // ذهب قديم مستلم من عميل
}

enum StockMovementType {
  PURCHASE       // شراء (دخول)
  SALE           // بيع (خروج)
  RETURN_IN      // مرتجع من عميل (دخول)
  RETURN_OUT     // مرتجع لمورد (خروج)
  TRANSFER_IN    // تحويل وارد بين فروع
  TRANSFER_OUT   // تحويل صادر بين فروع
  ADJUSTMENT_IN  // تسوية بالزيادة (جرد)
  ADJUSTMENT_OUT // تسوية بالنقصان (جرد)
  MANUFACTURE_IN // إنتاج وارد
  REPAIR_OUT     // إخراج للصيانة
  REPAIR_IN      // إرجاع من الصيانة
}

// ============================================================
// CORE MODELS
// ============================================================

/// الفروع (Branches / Locations)
model Branch {
  id          String   @id @default(cuid())
  code        String   @unique // e.g., "MAIN", "MOJ-01"
  name        String
  nameAr      String?
  address     String?
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products        Product[]
  stockMovements  StockMovement[]
  goldRates       GoldRate[]

  @@map("branches")
}

/// تصنيفات المنتجات (شجرة هرمية: مجوهرات > خواتم > خواتم زواج)
model Category {
  id          String     @id @default(cuid())
  name        String
  nameAr      String?
  slug        String     @unique
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  imageUrl    String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products    Product[]

  @@index([parentId])
  @@map("categories")
}

/// الموردون (سيتم توسيعها في وحدة CRM لاحقاً)
model Supplier {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameAr      String?
  contactName String?
  phone       String?
  email       String?
  taxNumber   String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  @@map("suppliers")
}

// ============================================================
// PRODUCTS — قلب وحدة المخزون
// ============================================================

/// المنتجات (قطع المجوهرات)
/// كل قطعة فريدة لها SKU و Barcode خاصين بها، حتى لو كانت من نفس التصميم.
/// هذا يختلف عن التجزئة العادية لأن وزن كل قطعة مختلف وسعرها يتغير.
model Product {
  id                 String         @id @default(cuid())
  sku                String         @unique // رقم تعريفي داخلي
  barcode            String?        @unique // باركود QR/EAN-13
  rfidTag            String?        @unique // RFID tag إن وُجد
  name               String
  nameAr             String?
  description        String?
  descriptionAr      String?

  // التصنيف والمورد
  categoryId         String
  category           Category       @relation(fields: [categoryId], references: [id])
  supplierId         String?
  supplier           Supplier?      @relation(fields: [supplierId], references: [id])
  branchId           String
  branch             Branch         @relation(fields: [branchId], references: [id])

  // معلومات المعدن
  metalType          MetalType      @default(GOLD)
  karat              Karat          @default(K22)

  // الأوزان (كل الأوزان بالجرام، Decimal دقيق)
  grossWeight        Decimal        @db.Decimal(12, 4) // الوزن الإجمالي
  netWeight          Decimal        @db.Decimal(12, 4) // وزن المعدن الصافي (بعد طرح الأحجار)
  stoneWeight        Decimal        @default(0) @db.Decimal(12, 4) // وزن الأحجار

  // وحدة البيع (هل تُباع بالقطعة أم بالجرام)
  sellingUnit        WeightUnit     @default(GRAM)

  // التسعير
  makingCharge       Decimal        @default(0) @db.Decimal(14, 4) // أجرة الصياغة (مقطوعة)
  makingChargePerGram Decimal       @default(0) @db.Decimal(14, 4) // أجرة الصياغة بالجرام
  fixedSalePrice     Decimal?       @db.Decimal(14, 4) // سعر بيع ثابت (للقطع التي تُباع بسعر ثابت)
  costPrice          Decimal?       @db.Decimal(14, 4) // التكلفة (سعر الشراء)

  // البصمة والشهادات
  hallmark           String?        // رقم البصمة الرسمية
  hallmarkedAt       DateTime?      // تاريخ التختيم
  hallmarkAuthority  String?        // جهة الاعتماد

  // الحالة والملكية
  status             ProductStatus  @default(IN_STOCK)
  ownershipType      OwnershipType  @default(OWNED)

  // الصور
  primaryImageUrl    String?
  imageUrls          String[]       @default([])

  // البيانات الفنية الإضافية (مرنة)
  designCode         String?        // رمز التصميم (للقطع المتشابهة)
  size               String?        // مقاس (للخواتم/الأساور)
  occasion           String?        // مناسبة (زواج، خطوبة، إلخ)
  notes              String?
  notesAr            String?

  // التواريخ
  receivedAt         DateTime?      // تاريخ استلام/إدخال المخزون
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?      // Soft delete

  // العلاقات
  stones             ProductStone[]
  stockMovements     StockMovement[]

  @@index([categoryId])
  @@index([branchId])
  @@index([status])
  @@index([metalType, karat])
  @@index([deletedAt])
  @@map("products")
}

/// أحجار المنتج (الألماس، الياقوت، الزمرد، إلخ)
/// قطعة واحدة قد تحتوي عدة أنواع أحجار - لذلك جدول منفصل
model ProductStone {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  stoneType      String   // "Diamond" | "Ruby" | "Emerald" | "Sapphire" | etc.
  stoneTypeAr    String?
  count          Int      // عدد الحبات
  caratWeight    Decimal  @db.Decimal(12, 4) // الوزن بالقيراط
  clarity        String?  // درجة النقاء (VVS1, VS2, etc.)
  color          String?  // اللون (D, E, F, etc. للألماس)
  cut            String?  // القَص (Excellent, Very Good, Good)
  shape          String?  // الشكل (Round, Princess, Oval)
  certificateNo  String?  // رقم شهادة GIA/IGI
  certificateUrl String?  // رابط الشهادة الممسوحة
  pricePerCarat  Decimal? @db.Decimal(14, 4) // سعر القيراط (اختياري لحساب القيمة)
  totalValue     Decimal? @db.Decimal(14, 4) // القيمة الإجمالية
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
  @@map("product_stones")
}

// ============================================================
// GOLD RATES — سعر الذهب اليومي
// ============================================================

/// أسعار الذهب اليومية (لكل عيار وكل فرع، مع تاريخ ووقت)
/// هذه الأسعار تُستخدم في وقت البيع لحساب قيمة القطعة.
/// يجب إدخالها صباح كل يوم.
model GoldRate {
  id           String     @id @default(cuid())
  branchId     String?    // إذا null = سعر عام لكل الفروع
  branch       Branch?    @relation(fields: [branchId], references: [id])
  metalType    MetalType  @default(GOLD)
  karat        Karat
  ratePerGram  Decimal    @db.Decimal(14, 4)
  currency     String     @default("OMR") // ISO currency code
  effectiveDate DateTime  @default(now())
  source       String?    // "manual" | "api:goldapi.io" | etc.
  notes        String?
  createdById  String?    // سيُربط بـ User لاحقاً
  createdAt    DateTime   @default(now())

  @@index([effectiveDate])
  @@index([branchId, karat, effectiveDate])
  @@map("gold_rates")
}

// ============================================================
// STOCK MOVEMENTS — حركات المخزون
// ============================================================

/// سجل كل حركة دخول أو خروج من المخزون.
/// هذا الجدول هو "Source of Truth" — حالة المخزون تُحسب منه.
model StockMovement {
  id            String            @id @default(cuid())
  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  branchId      String
  branch        Branch            @relation(fields: [branchId], references: [id])

  movementType  StockMovementType
  quantity      Int               @default(1) // عادةً 1 للمجوهرات لأن كل قطعة فريدة
  weightChange  Decimal           @db.Decimal(12, 4) // التغيّر في الوزن

  // المرجع (فاتورة، أمر شراء، تحويل، إلخ) — سيُربط لاحقاً
  referenceType String?  // "Invoice" | "PurchaseOrder" | "Transfer" | "Adjustment"
  referenceId   String?

  fromBranchId  String?  // للتحويلات
  toBranchId    String?

  reason        String?
  notes         String?
  performedById String?  // سيُربط بـ User لاحقاً
  movementDate  DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([branchId])
  @@index([movementType])
  @@index([movementDate])
  @@map("stock_movements")
}
