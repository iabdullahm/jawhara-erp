// JawharaERP — Multi-Tenant Schema
// Phase 1 (MVP): Inventory + Auth + Multi-Tenant Foundation

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum MetalType {
  GOLD
  SILVER
  PLATINUM
  PALLADIUM
  OTHER
}

enum Karat {
  K24
  K22
  K21
  K18
  K14
  K10
  K925
  K950
  OTHER
}

enum WeightUnit {
  GRAM
  CARAT
  PIECE
  OUNCE
}

enum ProductStatus {
  IN_STOCK
  SOLD
  RESERVED
  IN_REPAIR
  IN_MANUFACTURING
  CONSIGNMENT_OUT
  LOST
  WRITTEN_OFF
}

enum OwnershipType {
  OWNED
  CONSIGNMENT
  OLD_GOLD
}

enum PricingMode {
  DYNAMIC
  FIXED
  HYBRID
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN_IN
  RETURN_OUT
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  MANUFACTURE_IN
  REPAIR_OUT
  REPAIR_IN
}

/// أدوار المستخدمين في النظام
enum UserRole {
  PLATFORM_OWNER  // مالك المنصة (أنت) — يدير كل المحلات
  TENANT_OWNER    // مالك المحل
  MANAGER         // مدير فرع
  SALESPERSON     // بائع
  ACCOUNTANT      // محاسب
  GOLDSMITH       // صائغ/عامل تصنيع
  CASHIER         // كاشير
  VIEWER          // قراءة فقط
}

/// خطط الاشتراك
enum SubscriptionPlan {
  TRIAL       // فترة تجريبية مجانية
  BASIC       // أساسي
  PRO         // احترافي
  ENTERPRISE  // مؤسسات
}

/// حالة الاشتراك
enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELED
}

// ============================================================
// MULTI-TENANT CORE
// ============================================================

/// المحلات (المستأجرين)
/// كل محل عميل مستقل، له بياناته الخاصة المعزولة
model Tenant {
  id              String   @id @default(cuid())
  slug            String   @unique // jawhara-jewels, gold-palace, etc.
  name            String
  nameAr          String?
  businessNumber  String?  // السجل التجاري
  taxNumber       String?  // الرقم الضريبي
  phone           String?
  email           String?
  address         String?
  country         String   @default("OM")
  currency        String   @default("OMR")
  locale          String   @default("ar")
  logoUrl         String?
  isActive        Boolean  @default(true)

  // الاشتراك
  plan            SubscriptionPlan   @default(TRIAL)
  status          SubscriptionStatus @default(ACTIVE)
  trialEndsAt     DateTime?
  expiresAt       DateTime?

  // حدود الخطة (للفوترة لاحقاً)
  maxBranches     Int      @default(1)
  maxUsers        Int      @default(3)
  maxProducts     Int      @default(500)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // Relations
  users           User[]
  branches        Branch[]
  categories      Category[]
  suppliers       Supplier[]
  products        Product[]
  goldRates       GoldRate[]
  stockMovements  StockMovement[]

  @@index([slug])
  @@index([isActive, deletedAt])
  @@map("tenants")
}

/// المستخدمين
/// PLATFORM_OWNER: tenantId = null
/// كل المستخدمين الآخرين: ينتمون لـ tenant محدد
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  nameAr          String?
  phone           String?
  avatarUrl       String?

  role            UserRole

  // الانتماء للمحل (null لـ PLATFORM_OWNER)
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // الفرع الافتراضي (اختياري)
  defaultBranchId String?

  // حالة
  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  lastLoginIp     String?

  // Refresh token (مُجزأ)
  refreshTokenHash String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@map("users")
}

// ============================================================
// CORE BUSINESS MODELS (now with tenantId)
// ============================================================

model Branch {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String
  name        String
  nameAr      String?
  address     String?
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products        Product[]
  stockMovements  StockMovement[]
  goldRates       GoldRate[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

model Category {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  nameAr      String?
  slug        String
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  imageUrl    String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products    Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@map("categories")
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String
  name        String
  nameAr      String?
  contactName String?
  phone       String?
  email       String?
  taxNumber   String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("suppliers")
}

model Product {
  id                 String         @id @default(cuid())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sku                String
  barcode            String?
  rfidTag            String?
  name               String
  nameAr             String?
  description        String?
  descriptionAr      String?

  categoryId         String
  category           Category       @relation(fields: [categoryId], references: [id])
  supplierId         String?
  supplier           Supplier?      @relation(fields: [supplierId], references: [id])
  branchId           String
  branch             Branch         @relation(fields: [branchId], references: [id])

  metalType          MetalType      @default(GOLD)
  karat              Karat          @default(K22)

  grossWeight        Decimal        @db.Decimal(12, 4)
  netWeight          Decimal        @db.Decimal(12, 4)
  stoneWeight        Decimal        @default(0) @db.Decimal(12, 4)

  sellingUnit        WeightUnit     @default(GRAM)

  pricingMode        PricingMode    @default(DYNAMIC)
  makingCharge       Decimal        @default(0) @db.Decimal(14, 4)
  makingChargePerGram Decimal       @default(0) @db.Decimal(14, 4)
  fixedSalePrice     Decimal?       @db.Decimal(14, 4)
  costPrice          Decimal?       @db.Decimal(14, 4)
  safetyMarginPct    Decimal        @default(0) @db.Decimal(6, 2)

  hallmark           String?
  hallmarkedAt       DateTime?
  hallmarkAuthority  String?

  status             ProductStatus  @default(IN_STOCK)
  ownershipType      OwnershipType  @default(OWNED)

  primaryImageUrl    String?
  imageUrls          String[]       @default([])

  designCode         String?
  size               String?
  occasion           String?
  notes              String?
  notesAr            String?

  receivedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  stones             ProductStone[]
  stockMovements     StockMovement[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([categoryId])
  @@index([branchId])
  @@index([status])
  @@index([metalType, karat])
  @@index([deletedAt])
  @@map("products")
}

model ProductStone {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  stoneType      String
  stoneTypeAr    String?
  count          Int
  caratWeight    Decimal  @db.Decimal(12, 4)
  clarity        String?
  color          String?
  cut            String?
  shape          String?
  certificateNo  String?
  certificateUrl String?
  pricePerCarat  Decimal? @db.Decimal(14, 4)
  totalValue     Decimal? @db.Decimal(14, 4)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
  @@map("product_stones")
}

model GoldRate {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id])

  metalType    MetalType  @default(GOLD)
  karat        Karat
  ratePerGram  Decimal    @db.Decimal(14, 4)
  currency     String     @default("OMR")
  effectiveDate DateTime  @default(now())
  source       String?
  notes        String?
  createdById  String?
  createdAt    DateTime   @default(now())

  @@index([tenantId])
  @@index([effectiveDate])
  @@index([tenantId, branchId, karat, effectiveDate])
  @@map("gold_rates")
}

model StockMovement {
  id            String            @id @default(cuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  branchId      String
  branch        Branch            @relation(fields: [branchId], references: [id])

  movementType  StockMovementType
  quantity      Int               @default(1)
  weightChange  Decimal           @db.Decimal(12, 4)

  referenceType String?
  referenceId   String?

  fromBranchId  String?
  toBranchId    String?

  reason        String?
  notes         String?
  performedById String?
  movementDate  DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([productId])
  @@index([branchId])
  @@index([movementType])
  @@index([movementDate])
  @@map("stock_movements")
}
