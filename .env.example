# ============= Database =============
# للتطوير المحلي (Docker):
DATABASE_URL="postgresql://jawhara:jawhara_dev_pwd@localhost:5432/jawhara_erp?schema=public"
# للإنتاج (Neon/Supabase) - مثال:
# DATABASE_URL="postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/jawhara_erp?sslmode=require"

# ============= CORS (Production) =============
# في الإنتاج، حدد رابط الـ Frontend هنا (يفصل بفاصلة):
# CORS_ORIGINS="https://jewells-software.vercel.app"

# ============= Redis =============
REDIS_URL="redis://localhost:6379"

# ============= API =============
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# ============= Auth (will be used later) =============
JWT_SECRET="change-me-in-production-make-it-long-and-random"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ============= Frontend =============
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ============= Business Defaults =============
DEFAULT_CURRENCY="OMR"
DEFAULT_VAT_RATE=5
DEFAULT_LOCALE="ar"

# ============= External APIs =============
# مفتاح GoldAPI.io لجلب أسعار الذهب الحقيقية (سجّل مجاناً في goldapi.io)
# الحساب المجاني: 100 طلب شهرياً (كافي لتحديث يومي لـ 3 فروع)
GOLD_API_KEY=""
